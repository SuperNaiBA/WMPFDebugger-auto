<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>微信小程序调试器</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 20px;
            background-color: #f0f0f0;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
            background-color: white;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }
        h1 {
            color: #333;
            margin-top: 0;
            text-align: center;
        }
        .refresh-btn {
            background-color: #ff9800;
            color: white;
        }
        .refresh-btn:hover {
            background-color: #f57c00;
        }
        .clear-btn {
            background-color: #9c27b0;
            color: white;
        }
        .clear-btn:hover {
            background-color: #7b1fa2;
        }
        .instructions {
            margin-bottom: 30px;
            line-height: 1.6;
        }
        .button-group {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-bottom: 20px;
        }
        button {
            padding: 12px 24px;
            font-size: 16px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            transition: background-color 0.3s, transform 0.1s;
        }
        button:active {
            transform: scale(0.98);
        }
        .start-btn {
            background-color: #4CAF50;
            color: white;
        }
        .start-btn:hover {
            background-color: #45a049;
        }
        .stop-btn {
            background-color: #f44336;
            color: white;
        }
        .stop-btn:hover {
            background-color: #d32f2f;
        }
        .devtools-btn {
            background-color: #008CBA;
            color: white;
        }
        .devtools-btn:hover {
            background-color: #007399;
        }
        .status {
            margin-top: 20px;
            padding: 15px;
            border-radius: 4px;
            font-weight: bold;
            text-align: center;
        }
        .status.running {
            background-color: #e8f5e8;
            color: #2e7d32;
        }
        .status.stopped {
            background-color: #ffebee;
            color: #c62828;
        }
        .status.warning {
            background-color: #fff3e0;
            color: #f57c00;
        }
        .info {
            margin-top: 20px;
            padding: 10px;
            background-color: #e3f2fd;
            border-radius: 4px;
            font-size: 14px;
        }
        
        .feature-info {
            margin-top: 15px;
            padding: 12px;
            background-color: #e8f5e9;
            border-left: 4px solid #4CAF50;
            border-radius: 4px;
            font-size: 13px;
        }
        
        .feature-info ul {
            margin: 5px 0;
            padding-left: 20px;
        }
        
        .feature-info li {
            margin: 3px 0;
            line-height: 1.4;
        }
        
        .auto-notice {
            background-color: #fff3e0;
            padding: 8px 12px;
            border-radius: 4px;
            margin-top: 5px;
            font-size: 12px;
            color: #e65100;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>微信小程序调试器</h1>
        
        <div class="instructions">
            <p>这是WMPFDebugger的桌面版本界面。</p>
            <ol>
                <li>点击"启动调试器"按钮启动后端服务</li>
                <li><strong>自动功能：</strong>检测到微信小程序启动时会立即打开控制台</li>
                <li>点击"关闭调试器"按钮关闭后端服务</li>
            </ol>
            <div class="feature-info">
                <strong>✨ 新增功能：</strong>
                <ul>
                    <li>实时监控微信小程序进程（每秒检测一次）</li>
                    <li>智能识别：只对启动调试器后新开的小程序生效</li>
                    <li>检测到新小程序后0秒响应打开控制台</li>
                    <li>控制台关闭后，可再次自动打开新的小程序</li>
                </ul>
            </div>
            <div class="auto-notice">
                💡 注意：启动调试器时不会立即打开控制台，只有当您打开新的微信小程序时才会自动打开
            </div>
        </div>
        
        <div class="button-group">
            <button class="start-btn" id="startBtn" onclick="startServer()">启动调试器</button>
            <button class="stop-btn" id="stopBtn" onclick="stopServer()">关闭调试器</button>
            <button class="devtools-btn" id="devtoolsBtn" onclick="openDevTools()">打开控制台</button>
            <button class="refresh-btn" id="refreshBtn" onclick="refreshDevTools()">刷新控制台</button>
            <button class="clear-btn" id="clearBtn" onclick="clearLogs()">清空日志</button>
        </div>
        
        <div id="status" class="status stopped">未运行</div>
        
        <div id="log-container">
            <h3>运行日志</h3>
            <div id="log-output" class="log-output">
                <p>等待启动调试器...</p>
            </div>
        </div>
    </div>

    <style>
        #log-container {
            margin-top: 20px;
            border: 1px solid #eee;
            border-radius: 4px;
        }
        
        #log-container h3 {
            margin: 0;
            padding: 10px;
            background-color: #f5f5f5;
            border-bottom: 1px solid #eee;
            font-size: 16px;
        }
        
        .log-output {
            height: 300px;
            overflow-y: auto;
            padding: 10px;
            background-color: #fafafa;
            font-family: 'Courier New', monospace;
            font-size: 13px;
            line-height: 1.4;
        }
        
        .log-output p {
            margin: 0;
            padding: 2px 0;
        }
        
        .log-output .info {
            color: #2196F3;
        }
        
        .log-output .success {
            color: #4CAF50;
        }
        
        .log-output .warning {
            color: #FF9800;
        }
        
        .log-output .error {
            color: #F44336;
        }
    </style>

    <script>
        const electron = require('electron');
        const { ipcRenderer } = electron;
        let isRunning = false;
        
        // 更新按钮状态
        function updateButtonStates() {
            const startBtn = document.getElementById('startBtn');
            const stopBtn = document.getElementById('stopBtn');
            const devtoolsBtn = document.getElementById('devtoolsBtn');
            const refreshBtn = document.getElementById('refreshBtn');
            const clearBtn = document.getElementById('clearBtn');
            
            startBtn.disabled = isRunning;
            stopBtn.disabled = !isRunning;
            devtoolsBtn.disabled = !isRunning;
            refreshBtn.disabled = !isRunning;
            clearBtn.disabled = false; // 清空日志按钮始终可用
        }
        
        // 更新状态显示
        function updateStatus() {
            const statusDiv = document.getElementById('status');
            if (isRunning) {
                statusDiv.textContent = '运行中';
                statusDiv.className = 'status running';
            } else {
                statusDiv.textContent = '未运行';
                statusDiv.className = 'status stopped';
            }
        }
        
        // 添加日志到输出区域
        function addLog(type, message, timestamp) {
            const logOutput = document.getElementById('log-output');
            const logEntry = document.createElement('p');
            logEntry.className = type;
            logEntry.textContent = `[${timestamp}] ${message}`;
            logOutput.appendChild(logEntry);
            
            // 自动滚动到底部
            logOutput.scrollTop = logOutput.scrollHeight;
        }
        
        // 清空日志
        function clearLogs() {
            const logOutput = document.getElementById('log-output');
            logOutput.innerHTML = '<p>日志已清空</p>';
        }
        
        // 启动服务器
        function startServer() {
            clearLogs();
            addLog('info', '正在启动调试器...', new Date().toLocaleTimeString());
            ipcRenderer.send('start-server');
        }
        
        // 停止服务器
        function stopServer() {
            ipcRenderer.send('stop-server');
            addLog('info', '正在停止调试器...', new Date().toLocaleTimeString());
        }
        
        // 打开控制台
        function openDevTools() {
            ipcRenderer.send('open-devtools');
            addLog('info', '正在打开控制台...', new Date().toLocaleTimeString());
        }
        
        // 刷新控制台
        function refreshDevTools() {
            ipcRenderer.send('refresh-devtools');
        }
        
        // 监听服务器状态变化
        ipcRenderer.on('server-status', (event, data) => {
            isRunning = data.running;
            updateStatus();
            updateButtonStates();
        });
        
        // 监听日志消息
        ipcRenderer.on('log-message', (event, data) => {
            addLog(data.type, data.message, data.timestamp);
        });
        
        // 初始化
        updateButtonStates();
        updateStatus();
    </script>
</body>
</html>